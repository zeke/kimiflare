{
  "name": "kimiflare",
  "version": "0.85.0",
  "description": "A terminal coding agent powered by Kimi K2.6, routed through your own Cloudflare AI Gateway — per-request logs, response caching, authoritative cost. Web search, GitHub, headless browser, LSP, MCP, local memory, 262k context.",
  "keywords": [
    "ai",
    "cli",
    "coding-agent",
    "terminal",
    "kimi",
    "k2.6",
    "cloudflare",
    "ai-gateway",
    "workers-ai",
    "vision",
    "image-understanding",
    "llm",
    "code-generation",
    "tui",
    "mcp",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinameraji/kimiflare.git"
  },
  "homepage": "https://github.com/sinameraji/kimiflare#readme",
  "bugs": "https://github.com/sinameraji/kimiflare/issues",
  "license": "MIT",
  "type": "module",
  "bin": {
    "kimiflare": "bin/kimiflare.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "PLAN.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "build:remote": "npm run build:remote-agent",
    "build:remote-agent": "cd remote/agent && npx tsup",
    "dev": "tsx src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts src/**/*.test.tsx",
    "start": "node bin/kimiflare.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@resvg/resvg-js": "^2.6.2",
    "better-sqlite3": "^12.9.0",
    "commander": "^12.1.0",
    "ink": "^7.0.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "minimatch": "^10.2.5",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "turndown": "^7.2.0",
    "typescript": "^5.7.2",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "optionalDependencies": {
    "camouflage-tui": "beta",
    "isolated-vm": "^6.1.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.9.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.0",
    "@types/turndown": "^5.0.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2"
  }
}
